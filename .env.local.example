# Copy this file to .env.local and fill in your Supabase project values.
# Settings → API in your Supabase dashboard.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Secret path segment for the admin page, e.g. /admin/my-secret-123
NEXT_PUBLIC_ADMIN_SECRET=change-me-secret

# Optional — API-Football (api-sports.io) for injuries + projected lineups.
# Free plan: dashboard.api-football.com → copy the API key. Without it, the
# "Tin đội bóng" button just shows "chưa cấu hình". League/season default to the
# 2026 World Cup; override only if the lookup comes back empty.
API_FOOTBALL_KEY=
# API_FOOTBALL_LEAGUE=1
# API_FOOTBALL_SEASON=2026
